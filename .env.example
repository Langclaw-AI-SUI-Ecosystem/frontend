NEXT_PUBLIC_LANGCLAW_API_URL=/api/backend
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Public site origin, used for absolute OG image / icon URLs in metadata.
# On Vercel this falls back to VERCEL_URL automatically; set explicitly for the production domain.
NEXT_PUBLIC_SITE_URL=https://langclaw.ai
# Local dev or same-host VPS Next server only. Vercel must override this with a public Sui backend URL.
LANGCLAW_BACKEND_REWRITE_URL=http://127.0.0.1:3002
